{
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/internal/cron/resolve-cards",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/internal/cron/dispatch-notifications",
      "schedule": "10 3 * * *"
    },
    {
      "path": "/api/internal/cron/cleanup-rooms",
      "schedule": "0 4 * * *"
    }
  ]
}
