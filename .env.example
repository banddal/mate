# Supabase Dashboard > Project Settings > API > Project URL
# 예: https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase Dashboard > Project Settings > API > Project API keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Dashboard > Project Settings > API > Project API keys > service_role secret
SUPABASE_SERVICE_ROLE_KEY=

# 로그인은 Supabase Auth의 Google OAuth Provider를 사용한다.
# Google Client ID/Secret은 Supabase Dashboard > Authentication > Providers > Google에
# 등록하며, 앱 환경변수로 넣지 않는다.

# SMS 벤더 키 (미발급 상태). 키가 없으면 request-otp가 devOtp를 반환한다.
# 실제 SMS 발송 연동은 아직 구현되지 않았다.
SMS_VENDOR_API_KEY=

# App URL fallback. 브라우저 로그인은 현재 접속 origin을 우선 사용한다.
# Supabase 연결 URL이나 /auth/callback 주소를 넣지 않는다.
# 로컬은 http://localhost:3000, 운영/Vercel은 https://mate-161company.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
DISABLE_DEV_AUTH_BYPASS=0

# Web Push VAPID key pair.
# 생성: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Vercel Cron 인증용 시크릿. 내부 cron 엔드포인트는 이 값이 없으면 모든 요청을 거부한다.
CRON_SECRET=
