# Supabase Dashboard > Project Settings > API > Project URL
# 예: https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase Dashboard > Project Settings > API > Project API keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Dashboard > Project Settings > API > Project API keys > service_role secret
SUPABASE_SERVICE_ROLE_KEY=

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
SMS_VENDOR_API_KEY=

# App URL fallback. 브라우저 로그인은 현재 접속 origin을 우선 사용한다.
# Supabase 연결 URL이나 /auth/callback 주소를 넣지 않는다.
# 로컬은 http://localhost:3000, 운영/Vercel은 https://mate-161company.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
DISABLE_DEV_AUTH_BYPASS=0
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
CRON_SECRET=
